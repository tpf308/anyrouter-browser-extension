{
  "manifest_version": 3,
  "name": "AnyRouter Quota Monitor",
  "version": "2.4.0",
  "description": "在 Chrome 工具栏展示 AnyRouter 已使用额度，并主动探测 claude-opus-4-8 健康状态（主站 + 大陆直连双线路）。仅需一个 API Key。可选本地探测：用真实 Claude Code 请求探活，根治浏览器 fetch 的假 429。",
  "minimum_chrome_version": "110",
  "key": "",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "AnyRouter Quota",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://anyrouter.top/*",
    "https://a-ocnfniawgw.cn-shanghai.fcapp.run/*"
  ]
}
